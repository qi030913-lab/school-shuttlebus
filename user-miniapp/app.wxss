page {
  background: #f5f7fb;
  color: #333;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.small {
  color: #777;
  font-size: 26rpx;
}

.vehicle-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.input {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 18rpx;
}

.station-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.station-tag {
  padding: 10rpx 18rpx;
  background: #f0f7ff;
  color: #1677ff;
  border-radius: 999rpx;
  font-size: 24rpx;
}
