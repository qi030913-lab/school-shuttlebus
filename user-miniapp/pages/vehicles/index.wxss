.vehicles-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(27, 166, 155, 0.22), transparent 34%),
    radial-gradient(circle at 85% 12%, rgba(249, 170, 51, 0.18), transparent 24%),
    linear-gradient(180deg, #f2fbfa 0%, #f6f8fc 38%, #eef4f7 100%);
}

.vehicles-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(10rpx);
  opacity: 0.75;
}

.vehicles-glow-one {
  top: 48rpx;
  left: -70rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(21, 124, 116, 0.12);
}

.vehicles-glow-two {
  top: 420rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(249, 170, 51, 0.14);
}

.vehicles-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 24rpx 40rpx;
}

.list-card {
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(213, 226, 232, 0.82);
  box-shadow: 0 14rpx 36rpx rgba(19, 55, 73, 0.06);
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #123844;
}

.list-subtitle {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f8590;
}

.refresh-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #167c74, #0d5f67);
  color: #ffffff;
  font-size: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(16, 106, 102, 0.18);
}

.refresh-btn::after {
  border: none;
}

.vehicle-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.vehicle-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfcfd, #f5f9fb);
  border: 1rpx solid #e0ebf0;
}

.vehicle-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.vehicle-id {
  font-size: 30rpx;
  font-weight: 700;
  color: #123844;
}

.vehicle-driver {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6e8691;
}

.vehicle-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.vehicle-status-running {
  background: #e8fbf5;
  color: #0d8b60;
}

.vehicle-status-stopped {
  background: #eef3f7;
  color: #6f8290;
}

.vehicle-status-idle {
  background: #fff5e7;
  color: #b46d1c;
}

.vehicle-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.metric-box {
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.metric-label {
  font-size: 22rpx;
  color: #7a8f9b;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #163c47;
  font-weight: 600;
}

.vehicle-footer {
  margin-top: 20rpx;
  padding: 18rpx 16rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.78);
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.footer-row {
  display: block;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(244, 248, 250, 0.96);
}

.footer-label {
  display: block;
  font-size: 22rpx;
  color: #7a8f9b;
}

.footer-value {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #173b46;
  text-align: left;
  word-break: break-all;
  font-weight: 600;
}

.empty-block {
  padding: 36rpx 20rpx;
  border-radius: 22rpx;
  background: #f6fafc;
  color: #718794;
  text-align: center;
  font-size: 24rpx;
}
