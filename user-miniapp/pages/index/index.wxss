.page-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(27, 166, 155, 0.22), transparent 34%),
    radial-gradient(circle at 85% 12%, rgba(249, 170, 51, 0.18), transparent 24%),
    linear-gradient(180deg, #f2fbfa 0%, #f6f8fc 38%, #eef4f7 100%);
}

.glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(10rpx);
  opacity: 0.75;
}

.glow-one {
  top: 48rpx;
  left: -70rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(21, 124, 116, 0.12);
}

.glow-two {
  top: 420rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(249, 170, 51, 0.14);
}

.page-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 24rpx 40rpx;
}

.hero-card {
  padding: 26rpx 24rpx 28rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 16% 0%, rgba(255, 215, 141, 0.36), transparent 28%),
    radial-gradient(circle at 84% 16%, rgba(178, 242, 255, 0.18), transparent 26%),
    linear-gradient(180deg, #3e8c97 0%, #195f70 26%, #0b3f55 58%, #082c42 100%);
  color: #ffffff;
  box-shadow: 0 28rpx 56rpx rgba(7, 41, 57, 0.24);
}

.route-showcase {
  padding: 18rpx 6rpx 12rpx;
}

.route-showcase-badge {
  position: absolute;
  top: -10rpx;
  right: 10rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(235, 248, 251, 0.84);
  color: #285466;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 22rpx rgba(5, 36, 49, 0.16);
}

.route-showcase-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.route-showcase-icon-shell {
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.route-showcase-icon {
  width: 86rpx;
  height: 86rpx;
  filter: brightness(0) invert(1);
}

.route-showcase-copy {
  min-width: 0;
  flex: 1;
}

.route-showcase-title-box {
  position: relative;
  display: inline-block;
  max-width: 100%;
  padding-right: 138rpx;
}

.route-showcase-name {
  display: inline-block;
  max-width: 100%;
  font-size: 60rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 6rpx 20rpx rgba(6, 33, 48, 0.2);
  font-family: "DIN Alternate", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.route-showcase-metrics {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 26rpx;
}




.route-progress-track {
  position: relative;
  margin-top: 18rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(175, 231, 238, 0.28);
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.route-progress-fill {
  position: relative;
  height: 100%;
  min-width: 18%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #42eff4 0%, #57f7ff 55%, #a5ffff 100%);
  box-shadow: 0 0 16rpx rgba(91, 248, 255, 0.85);
}

.route-progress-fill::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -10rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  transform: translateY(-50%);
  background: #cfffff;
  box-shadow: 0 0 20rpx rgba(144, 255, 255, 0.95);
}

.hero-info-card {
  margin-top: 24rpx;
  padding: 6rpx 0 0;
  border-top: 5rpx solid rgb(35, 201, 140);
}

.hero-info-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-info-head-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(173, 244, 255, 0.12);
  border: 1rpx solid rgba(173, 244, 255, 0.24);
  color: rgba(226, 253, 255, 0.88);
  font-size: 21rpx;
}

.hero-stat-label {
  font-size: 46rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.hero-speed-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.hero-speed-row {
  position: relative;
  display: block;
  padding: 20rpx 22rpx 22rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(186, 227, 236, 0.2), rgba(104, 149, 164, 0.12)),
    rgba(135, 185, 201, 0.12);
  border: 1rpx solid rgba(225, 247, 252, 0.18);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.34),
    inset 0 -8rpx 18rpx rgba(6, 37, 53, 0.18),
    0 18rpx 32rpx rgba(4, 28, 41, 0.18);
  backdrop-filter: blur(18rpx);
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.hero-speed-row-active {
  transform: scale(0.98);
  opacity: 0.92;
}

.hero-speed-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-speed-main {
  min-width: 0;
  flex: 1;
}

.hero-vehicle-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.hero-vehicle-dot {
  width: 18rpx;
  height: 18rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  box-shadow: 0 0 14rpx currentColor;
}

.hero-vehicle-dot-running {
  color: #8fff9d;
  background: #8fff9d;
}

.hero-vehicle-dot-idle {
  color: #8ee8ff;
  background: #8ee8ff;
}

.hero-speed-vehicle {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.hero-speed-driver {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(226, 246, 251, 0.7);
}

.hero-speed-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(189, 239, 255, 0.12);
  color: rgba(229, 250, 255, 0.84);
  font-size: 22rpx;
  white-space: nowrap;
}

.hero-speed-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.hero-speed-metric {
  min-width: 0;
  flex: 1;
}

.hero-distance-metric {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.hero-speed-caption {
  font-size: 20rpx;
  color: rgba(202, 237, 245, 0.66);
}

.hero-speed-value-line {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 10rpx;
}

.hero-speed-distance {
  font-size: 20rpx;
  color: rgba(222, 247, 250, 0.76);
  margin-top: 10rpx;
  text-align: right;
}

.hero-speed-value {
  font-size: 58rpx;
  line-height: 1;
  color: #86ff93;
  font-weight: 700;
  text-shadow: 0 0 14rpx rgba(134, 255, 147, 0.35);
  font-family: "DIN Alternate", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.hero-speed-unit {
  font-size: 22rpx;
  color: rgba(236, 249, 251, 0.86);
}

.hero-speed-empty {
  margin-top: 16rpx;
  padding: 30rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(186, 227, 236, 0.12);
  color: rgba(226, 246, 251, 0.76);
  font-size: 22rpx;
  text-align: center;
}

.panel-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(213, 226, 232, 0.82);
  box-shadow: 0 14rpx 36rpx rgba(19, 55, 73, 0.06);
}

.map-panel {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(245, 251, 250, 0.96));
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.compact-head {
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #123844;
}

.panel-subtitle {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f8590;
}

.refresh-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #167c74, #0d5f67);
  color: #ffffff;
  font-size: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(16, 106, 102, 0.18);
}

.refresh-btn::after {
  border: none;
}

.map-view {
  width: 100%;
  height: 560rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
