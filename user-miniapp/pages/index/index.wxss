.page-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(27, 166, 155, 0.22), transparent 34%),
    radial-gradient(circle at 85% 12%, rgba(249, 170, 51, 0.18), transparent 24%),
    linear-gradient(180deg, #f2fbfa 0%, #f6f8fc 38%, #eef4f7 100%);
}

.glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(10rpx);
  opacity: 0.75;
}

.glow-one {
  top: 48rpx;
  left: -70rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(21, 124, 116, 0.12);
}

.glow-two {
  top: 420rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(249, 170, 51, 0.14);
}

.page-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 24rpx 40rpx;
}

.hero-card {
  padding: 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(8, 55, 68, 0.96), rgba(18, 103, 95, 0.92));
  color: #ffffff;
  box-shadow: 0 24rpx 48rpx rgba(12, 56, 66, 0.18);
}

.route-showcase {
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.17), rgba(255, 255, 255, 0.08));
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(12rpx);
}

.route-showcase-label {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.74);
}

.route-showcase-name {
  margin-top: 16rpx;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  font-family: "DIN Alternate", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.route-showcase-time {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.78);
}

.hero-info-card {
  margin-top: 18rpx;
  padding: 24rpx 24rpx 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.hero-stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.hero-speed-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 14rpx;
}

.hero-speed-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-speed-main {
  min-width: 0;
  flex: 1;
}

.hero-speed-vehicle {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

.hero-speed-driver {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.64);
}

.hero-speed-distance {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(196, 245, 232, 0.88);
}

.hero-speed-value {
  font-size: 26rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  font-family: "DIN Alternate", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.hero-speed-empty {
  margin-top: 16rpx;
  padding: 26rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  text-align: center;
}

.panel-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(213, 226, 232, 0.82);
  box-shadow: 0 14rpx 36rpx rgba(19, 55, 73, 0.06);
}

.map-panel {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(245, 251, 250, 0.96));
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.compact-head {
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #123844;
}

.panel-subtitle {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f8590;
}

.refresh-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #167c74, #0d5f67);
  color: #ffffff;
  font-size: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(16, 106, 102, 0.18);
}

.refresh-btn::after {
  border: none;
}

.map-view {
  width: 100%;
  height: 560rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
