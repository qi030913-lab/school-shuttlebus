<view class="page-shell">
  <view class="glow glow-one"></view>
  <view class="glow glow-two"></view>

  <view class="page-content">
    <view class="hero-card">
      <picker mode="selector" range="{{routes}}" range-key="routeName" value="{{routeIndex}}" bindchange="onRouteChange">
        <view class="route-showcase">
          <view class="route-showcase-label">当前线路</view>
          <view class="route-showcase-name">{{routeName || '摆渡线路总览'}}</view>
          <view class="route-showcase-time">服务时段 {{routeServiceTime || '加载中...'}}</view>
        </view>
      </picker>

      <view class="stats-grid hero-stats-grid">
        <view class="stat-card hero-stat-card" bindtap="goToVehiclesPage">
          <view class="stat-label hero-stat-label">在线车辆</view>
          <view class="stat-value hero-stat-value">{{liveVehicleCount}}</view>
          <view class="stat-hint hero-stat-hint">当前线路可见车辆</view>
        </view>
        <view class="stat-card hero-stat-card hero-info-card">
          <view class="stat-label hero-stat-label">实时车速</view>
          <block wx:if="{{vehicles.length}}">
            <view class="hero-speed-list">
              <view wx:for="{{vehicles}}" wx:key="vehicleId" class="hero-speed-row">
                <view class="hero-speed-main">
                  <view class="hero-speed-vehicle">{{item.vehicleId}}</view>
                  <view class="hero-speed-driver">{{item.driverName || '未登记司机'}}</view>
                </view>
                <view class="hero-speed-value">{{item.speedText}}</view>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="hero-speed-empty">当前线路暂无在线车辆</view>
          </block>
        </view>
      </view>
    </view>

    <view class="panel-card map-panel">
      <view class="panel-head">
        <view>
          <view class="panel-title">线路地图</view>
        </view>
        <button class="refresh-btn" size="mini" loading="{{refreshing}}" bindtap="loadOverview">刷新</button>
      </view>
      <map
        class="map-view"
        longitude="{{mapLongitude}}"
        latitude="{{mapLatitude}}"
        scale="15"
        markers="{{markers}}"
        polyline="{{polyline}}"
        show-location
      ></map>
    </view>

  </view>
</view>
