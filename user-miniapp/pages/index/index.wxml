<view class="page-shell">
  <view class="glow glow-one"></view>
  <view class="glow glow-two"></view>

  <view class="page-content">
    <view class="hero-card">
      <picker mode="selector" range="{{routes}}" range-key="routeName" value="{{routeIndex}}" bindchange="onRouteChange">
        <view class="route-showcase">
          <view class="route-showcase-main">
            <view class="route-showcase-icon-shell">
              <image class="route-showcase-icon" src="/assets/logo-1024.png" mode="aspectFit"></image>
            </view>
            <view class="route-showcase-copy">
              <view class="route-showcase-title-box">
                <view class="route-showcase-name">{{routeName || '摆渡线路总览'}}</view>
                <view class="route-showcase-badge">当前线路</view>
              </view>
            </view>
          </view>
          <view class="route-showcase-metrics">
            <view class="route-showcase-label">服务时段</view>
            <view class="route-showcase-time">{{routeServiceTime || '加载中...'}}</view>
          </view>
          <!-- <view class="route-progress-track">
            <view class="route-progress-fill" style="width: {{routeProgressWidth}};"></view>
          </view> -->
        </view>
      </picker>

      <view class="hero-info-card">
        <view class="hero-info-head">
          <view class="hero-stat-label">实时车辆</view>
        </view>
        <block wx:if="{{vehicles.length}}">
          <view class="hero-speed-list">
            <view
              wx:for="{{vehicles}}"
              wx:key="vehicleId"
              class="hero-speed-row"
              bindtap="goToVehicleDetail"
              data-vehicle-id="{{item.vehicleId}}"
              hover-class="hero-speed-row-active"
              hover-stay-time="80"
            >
              <view class="hero-speed-top">
                <view class="hero-speed-main">
                  <view class="hero-vehicle-meta">
                    <view class="hero-vehicle-dot {{item.status === 'RUNNING' ? 'hero-vehicle-dot-running' : 'hero-vehicle-dot-idle'}}"></view>
                    <view class="hero-speed-vehicle">{{item.vehicleId}}</view>
                  </view>
                  <view class="hero-speed-driver">{{item.driverName || '未登记司机'}}</view>
                </view>
                <view class="hero-speed-tag">{{item.status === 'RUNNING' ? '在线' : '停运'}}</view>
              </view>
              <view class="hero-speed-bottom">
                <view class="hero-speed-metric">
                  <view class="hero-speed-caption">当前速度</view>
                  <view class="hero-speed-value-line">
                    <view class="hero-speed-value">{{item.speedValueText}}</view>
                    <view class="hero-speed-unit">{{item.speedUnitText}}</view>
                  </view>
                </view>
                <view class="hero-distance-metric">
                  <view class="hero-speed-caption">与您距离</view>
                  <view class="hero-speed-distance">{{item.distanceText}}</view>
                </view>
              </view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="hero-speed-empty">当前线路暂无在线车辆</view>
        </block>
      </view>
    </view>

    <view class="panel-card map-panel">
      <view class="panel-head">
        <view>
          <view class="panel-title">线路地图</view>
          <view class="panel-subtitle">{{userLocationText}}</view>
        </view>
        <button class="refresh-btn" size="mini" loading="{{refreshing}}" bindtap="refreshAll">刷新</button>
      </view>
      <map
        class="map-view"
        longitude="{{mapLongitude}}"
        latitude="{{mapLatitude}}"
        scale="15"
        markers="{{markers}}"
        polyline="{{polyline}}"
      ></map>
    </view>
  </view>
</view>
