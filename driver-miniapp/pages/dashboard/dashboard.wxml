<view class="container">
  <view class="card">
    <view class="title">{{labels.panelTitle}}</view>
    <view class="row"><text>{{labels.driver}}</text><text>{{driverName}}</text></view>
    <view class="row"><text>{{labels.vehicle}}</text><text>{{vehicleId}}</text></view>
    <view class="row"><text>{{labels.route}}</text><text>{{routeName}} ({{routeId}})</text></view>
    <view class="row"><text>{{labels.loginMode}}</text><text>{{mockMode ? labels.mockMode : labels.realLogin}}</text></view>
    <view class="row"><text>{{labels.status}}</text><text>{{tripStatus}}</text></view>
    <view class="row"><text>{{labels.latitude}}</text><text>{{latitude}}</text></view>
    <view class="row"><text>{{labels.longitude}}</text><text>{{longitude}}</text></view>
    <view class="row"><text>{{labels.speed}}</text><text>{{speed}}</text></view>

    <view class="button-group">
      <button type="primary" bindtap="startTrip">{{labels.startTrip}}</button>
      <button bindtap="uploadOnce">{{labels.uploadOnce}}</button>
      <button wx:if="{{autoUpload}}" bindtap="toggleAutoUpload">{{labels.stopAutoUpload}}</button>
      <button wx:else bindtap="toggleAutoUpload">{{labels.startAutoUpload}}</button>
      <button wx:if="{{testing}}" bindtap="toggleTestLocation">{{labels.stopTest}}</button>
      <button wx:else bindtap="toggleTestLocation">{{labels.startTestRoute}}</button>
      <button type="warn" bindtap="stopTrip">{{labels.stopTrip}}</button>
      <button bindtap="logout">{{labels.logout}}</button>
    </view>
  </view>
</view>
